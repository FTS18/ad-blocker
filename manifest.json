{
  "manifest_version": 3,
  "name": "AdVoid - MV3 Ad Blocker & YouTube Shield",
  "version": "1.4",
  "description": "Lightweight Manifest V3 ad blocker. Block display ads, skip YouTube video ads instantly, and secure your privacy.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "activeTab",
    "webNavigation",
    "scripting",
    "privacy"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["cosmetic.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "options_page": "options.html",
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_ads",
        "enabled": true,
        "path": "rules/ads.json"
      },
      {
        "id": "ruleset_trackers",
        "enabled": true,
        "path": "rules/trackers.json"
      },
      {
        "id": "ruleset_annoyances",
        "enabled": true,
        "path": "rules/annoyances.json"
      },
      {
        "id": "ruleset_malware",
        "enabled": true,
        "path": "rules/malware.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["stubs/ga.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
